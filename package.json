{
  "name": "voicegis",
  "version": "2.0.0-alpha.1",
  "description": "Voice-Enabled Geospatial Map Web Application — offline-first voice command interface for Leaflet and OpenLayers",
  "main": "dist/voicegis.umd.js",
  "module": "dist/voicegis.es.js",
  "types": "dist/types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/voicegis.es.js",
      "require": "./dist/voicegis.umd.js"
    },
    "./engines": "./src/engines/index.js",
    "./parser": "./src/parser/index.js",
    "./map": "./src/map/index.js",
    "./evaluation": "./src/evaluation/index.js"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:types",
    "build:types": "tsc --project jsconfig.json || exit 0",
    "preview": "vite preview",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "lint": "eslint src/ demo/"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  },
  "keywords": [
    "voicegis",
    "voice",
    "gis",
    "leaflet",
    "openlayers",
    "speech",
    "whisper",
    "tensorflow",
    "maps",
    "wms",
    "geospatial",
    "offline",
    "pwa"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "leaflet": "^1.9.0",
    "ol": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "leaflet": {
      "optional": true
    },
    "ol": {
      "optional": true
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@tensorflow-models/speech-commands": "^0.5.4",
    "@tensorflow/tfjs": "^4.17.0",
    "@tensorflow/tfjs-backend-webgl": "^4.17.0",
    "leaflet": "^1.9.0",
    "ol": "^9.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/ol": "^6.5.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  }
}
